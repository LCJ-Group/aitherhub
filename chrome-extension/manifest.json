{
  "manifest_version": 3,
  "name": "AitherHub LIVE Connector",
  "version": "2.0.0",
  "description": "TikTok Shop LIVEデータをAitherHubに送信。配信画面+ダッシュボード2画面同期で商品反応の時系列DBを構築",
  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "https://shop.tiktok.com/*",
    "https://*.aitherhub.com/*",
    "https://aitherhubapi-cpcjcnezbgf5f7e2.japaneast-01.azurewebsites.net/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://shop.tiktok.com/streamer/*"
      ],
      "js": [
        "src/selectors.js",
        "src/parser_live.js",
        "src/content_live.js"
      ],
      "css": ["src/content.css", "src/minibar.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://shop.tiktok.com/workbench/live/*"
      ],
      "js": [
        "src/selectors.js",
        "src/parser_dashboard.js",
        "src/content_dashboard.js"
      ],
      "css": ["src/content.css", "src/minibar.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://aitherhub.com/*",
        "https://www.aitherhub.com/*"
      ],
      "js": ["src/aitherhub_bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
