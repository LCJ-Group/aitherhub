# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=liveboost

# Azure Storage (replace with your real values)
AZURE_STORAGE_ACCOUNT_NAME=your-account-name
AZURE_QUEUE_NAME=video-jobs
AZURE_BLOB_CONTAINER=videos
AZURE_BLOB_SAS_EXP_MINUTES=60
AZURE_BLOB_SAS_DOWNLOAD_MINUTES=1440

# Production Azure example
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account-name;AccountKey=your-account-key;EndpointSuffix=core.windows.net

# Local Azurite example
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://localhost:10000/devstoreaccount1;QueueEndpoint=http://localhost:10001/devstoreaccount1;

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/liveboost

OPENAI_API_KEY=your-openai-api-key-here
# Tencent Cloud Digital Human (數智人) IVH API
TENCENT_IVH_BASE_URL=https://gw.tvs.qq.com
TENCENT_IVH_APPKEY=your-tencent-ivh-appkey
TENCENT_IVH_ACCESS_TOKEN=your-tencent-ivh-access-token
TENCENT_IVH_PROJECT_ID=your-virtualman-project-id
TENCENT_IVH_PROTOCOL=rtmp

# ElevenLabs Voice Cloning TTS (Hybrid Mode)
# Required for hybrid mode: use_hybrid_voice=true
# Supports 32+ languages including Japanese
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-default-voice-id
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# FaceFusion GPU Worker (Mode B: Real Face Livestream)
# The GPU worker runs FaceFusion on a cloud GPU server (Vast.ai / RunPod)
# and exposes an HTTP API for real-time face swapping
FACE_SWAP_WORKER_URL=http://your-gpu-worker:8000
FACE_SWAP_WORKER_API_KEY=your-worker-api-key
FACE_SWAP_CONNECT_TIMEOUT=10
FACE_SWAP_READ_TIMEOUT=120
FACE_SWAP_RESOLUTION=720p
FACE_SWAP_FPS=30
