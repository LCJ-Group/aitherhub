{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/widget/*", "/*.{css,scss,js,json,txt,xml,ico,png,jpg,jpeg,gif,svg,woff,woff2,ttf,eot}"]
  },
  "routes": [
    {
      "route": "/widget/loader.js",
      "headers": {
        "Cache-Control": "no-cache, must-revalidate, max-age=0"
      }
    },
    {
      "route": "/loader.js",
      "rewrite": "/widget/loader.js",
      "headers": {
        "Cache-Control": "no-cache, must-revalidate, max-age=0"
      }
    },
    {
      "route": "/api/*",
      "backend": "aitherhubAPI"
    }
  ],
  "globalHeaders": {
    "X-Frame-Options": "SAMEORIGIN"
  }
}
